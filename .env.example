# Google AI（Gemini）OpenAI 互換 API 用
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_ai_studio_api_key_here

# 社内 UTM / SSL インスペクション用のルート CA（PEM）。省略時はプロジェクト直下の SecurityAppliance_SSL_CA.pem を自動使用
# SSL_CA_BUNDLE=SecurityAppliance_SSL_CA.pem
# OpenSSL 3 の厳格検証緩和（VERIFY_X509_STRICT）。PEM を使う場合は未指定で自動で有効。厳格にしたいときだけ false
# SSL_RELAX_X509_STRICT=false

# 既定モデル: gemini-2.5-flash, gemini-2.5-flash-lite, ollama-qwen3.5-9b（Ollama の実名に合わせる）等
AI_MODEL=gemini-2.5-flash
# AI API呼び出しのタイムアウト（秒）。Ollama等で長時間かかる場合は増やす（例: 300）
# AI_TIMEOUT=300
# 1応答あたりの最大トークン（長文・繰り返し暴走の抑止。必要なら増やす）
# AI_MAX_TOKENS=2000
# Excel 生成専用の上限（表・チャート入り JSON が長い。未設定時は max(AI_MAX_TOKENS, 16384)）
# AI_EXCEL_MAX_TOKENS=32768
PEXELS_API_KEY=your_pexels_api_key_here
# network_mode: host 使用時は localhost で接続
# OLLAMA_BASE_URL=http://localhost:11434/v1
